    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "export:slides": "npm run build:addons && node scripts/export-slides.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-docs": "node scripts/generate-docs-pdf.mjs",
    "generate-screenshots": "node scripts/screenshot/capture-screenshots.mjs",
    "screenshots:compare": "node scripts/screenshot/compare.mjs"
  },
