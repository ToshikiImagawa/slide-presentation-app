{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "presenterView"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "store:default"
  ]
}
